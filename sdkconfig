CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="4MB"
CONFIG_ESPTOOLPY_HEADER_OVERRIDE="0"
CONFIG_PARTITION_TABLE_SINGLE_APP_LARGE=y
CONFIG_ESPTOOLPY_BAUD_921600B=y

# ESP32-S3 specific
CONFIG_IDF_TARGET_ESP32S3=y
CONFIG_ESP32S3_DATA_CACHE_8KB=y
CONFIG_ESP32S3_DATA_CACHE_8KB_MODE=y

# WiFi
CONFIG_ESP32_WIFI_STATIC_RX_BUFFER_NUM=10
CONFIG_ESP32_WIFI_DYNAMIC_RX_BUFFER_NUM=32
CONFIG_ESP32_WIFI_DYNAMIC_TX_BUFFER_NUM=32

# WebSocket
CONFIG_ESP_WS_BUFFER_SIZE=4096
CONFIG_ESP_WS_PING_INTERVAL_SEC=30

# Audio (ES8311)
CONFIG_ESP32S3_I2S_NUM=1

# LCD (ST7789)
CONFIG_LCD_ST7789=y
CONFIG_LCD_SPI_CLOCK_HZ=40000000

# FreeRTOS
CONFIG_FREERTOS_HZ=1000

# Logging
CONFIG_LOG_DEFAULT_LEVEL_INFO=y
CONFIG_LOG_MAXIMUM_LEVEL_VERBOSE=y
